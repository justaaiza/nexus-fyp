# ── Server ──────────────────────────────────────
PORT=5000

# ── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nexus-fyp?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
